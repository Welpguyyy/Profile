{
  "version": 2,
  "builds": [
    {
      "src": "my-portfolio/package.json",
      "use": "@vercel/next",
      "config": {
        "maxLambdaSize": "50mb",
        "outputDirectory": ".next"
      }
    }
  ],
  "routes": [
    { "src": "/api/.*", "dest": "/api" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
